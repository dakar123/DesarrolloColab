# Dependencias
node_modules/

yarn.lock

# Archivos de entorno (contienen credenciales)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos del sistema operativo
.DS_Store
Thumbs.db
*.swp
*.swo

# Directorios de IDEs
.vscode/
.idea/
*.sublime-*

# Archivos de Docker (si no quieres subir volúmenes locales)
# (Render construye desde cero, no necesita volúmenes locales)
docker-compose.override.yml
postgres_data/
mysql_data/

# Archivos de respaldo SQL locales (opcional, mejor mantener init.sql)
*.sql.bak
*.sql.gz

# Archivos de cobertura y testing
coverage/
.nyc_output/

# Archivos de configuración de Render (se genera automáticamente)
render.yaml.bak

# Archivos temporales
tmp/
temp/